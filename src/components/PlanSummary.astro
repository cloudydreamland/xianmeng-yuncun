---
import type { CollectionEntry } from 'astro:content';
import { calculatePlanProgress, comparePlans } from '../utils/planProgress';

interface Props { plans: CollectionEntry<'plans'>[]; }
const { plans } = Astro.props;
const sorted = [...plans].sort((left, right) => comparePlans(left.data, right.data));
const featured = sorted.filter(({ data }) => data.featured && data.status === '进行中');
const selected = [...featured, ...sorted.filter((plan) => !featured.includes(plan) && plan.data.status === '进行中')].slice(0, 3);
---

{selected.length > 0 && (
  <section class="home-plan-summary" aria-labelledby="home-plan-summary-title">
    <header><div><p class="pixel-kicker">月潭推进</p><h3 id="home-plan-summary-title">此刻正在做什么</h3></div><a href="/world/moon-pool/#plan-dashboard-title">查看完整推进台 →</a></header>
    <div>
      {selected.map((plan) => {
        const progress = calculatePlanProgress(plan.data.milestones);
        const action = plan.data.nextActions.find(({ status }) => status !== '已完成');
        return <a class="home-plan-card" href={`/world/moon-pool/${plan.data.slug}/`}>
          <span>{plan.data.area} · {plan.data.priority}优先</span>
          <h4>{plan.data.title}</h4>
          <div><span style={`width:${progress ?? 0}%`}></span></div>
          <p>{progress === null ? '待拆解里程碑' : `里程碑完成 ${progress}%`}</p>
          {action && <small>下一步：{action.title}</small>}
        </a>;
      })}
    </div>
  </section>
)}

<style>
  .home-plan-summary { grid-column: 1 / -1; padding: 24px; border: 3px solid #5e6e63; background: rgba(232,238,218,.9); box-shadow: 6px 6px 0 rgba(54,66,57,.28); }
  .home-plan-summary > header { display: flex; align-items: end; justify-content: space-between; gap: 20px; margin-bottom: 18px; }
  .home-plan-summary h3 { margin: 0; color: #514838; font-family: var(--serif); font-size: 1.55rem; }
  .home-plan-summary > header a { color: #426753; font-size: .75rem; font-weight: 900; }
  .home-plan-summary > div { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }
  .home-plan-card { padding: 17px 18px; border: 2px solid #7d897f; color: #556159; background: #f6f3db; transition: transform .18s ease, box-shadow .18s ease; }
  .home-plan-card:hover { transform: translateY(-3px); box-shadow: 4px 4px 0 rgba(67,78,69,.24); }
  .home-plan-card > span, .home-plan-card p, .home-plan-card small { display: block; font-size: .68rem; }
  .home-plan-card h4 { margin: 7px 0 12px; color: #514838; font-family: var(--serif); font-size: 1.05rem; }
  .home-plan-card > div { height: 8px; overflow: hidden; border: 1px solid #68776d; background: #d5ddce; }
  .home-plan-card > div span { display: block; height: 100%; background: #78a083; }
  .home-plan-card p { margin: 7px 0; color: #657168; }
  .home-plan-card small { color: #3f6652; font-weight: 800; }
  @media (max-width: 900px) { .home-plan-summary > div { grid-template-columns: 1fr; } }
  @media (max-width: 600px) { .home-plan-summary > header { align-items: start; flex-direction: column; } }
  @media (prefers-reduced-motion: reduce) { .home-plan-card { transition: none; } }
</style>
