---
const pathname = Astro.url.pathname;

interface NavLink {
  href: string;
  label: string;
  match?: string[];
}

const links: NavLink[] = [
  { href: '/', label: '云村', match: ['/', '/world/cloud-village/'] },
  { href: '/world/rain-bridge/', label: '雨桥' },
  { href: '/world/star-abyss/', label: '星渊' },
  { href: '/world/wind-valley/', label: '风谷' },
  { href: '/world/moon-pool/', label: '月潭' },
  { href: '/world/snow-cliff/', label: '雪崖' },
  { href: '/world/lantern-lane/', label: '浮屿·灯巷' },
  { href: '/about', label: '个人主页' },
];

const isActive = (link: NavLink) => {
  if (link.match?.includes(pathname)) return true;
  if (link.href === '/') return pathname === '/';
  return pathname.startsWith(link.href);
};
---

<header class="site-header">
  <a class="site-brand" href="/" aria-label="雲梦世界首页">
    <span class="site-brand__mark" aria-hidden="true">雲</span>
    <span><strong>雲梦世界</strong><small>云村与六境</small></span>
  </a>
  <nav class="desktop-nav pixel-hud" aria-label="主导航">
    {links.map((link) => (
      <a href={link.href} class:list={[{ active: isActive(link) }]} aria-current={isActive(link) ? 'page' : undefined}>
        {link.label}
      </a>
    ))}
    <button type="button" class="nav-search" data-search-open aria-label="搜索云村内容">
      <span aria-hidden="true">⌕</span><span>云镜</span><kbd>⌘K</kbd>
    </button>
  </nav>
  <details class="mobile-nav">
    <summary aria-label="打开导航"><span></span><span></span><span></span></summary>
    <nav aria-label="移动端导航">
      {links.map((link) => <a href={link.href} aria-current={isActive(link) ? 'page' : undefined}>{link.label}</a>)}
      <button type="button" class="mobile-search" data-search-open><span aria-hidden="true">⌕</span> 打开云镜</button>
    </nav>
  </details>
</header>
