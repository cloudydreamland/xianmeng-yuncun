---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import IslandTag from './IslandTag';

interface Props {
  works: CollectionEntry<'works'>[];
}

const { works } = Astro.props;
const categories = [...new Set(works.map(({ data }) => data.category))];
const tags = [...new Set(works.flatMap(({ data }) => data.tags))];
const formatDate = (date: Date) => new Intl.DateTimeFormat('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' }).format(date);
---

<section class="gallery-archive" data-gallery-browser aria-labelledby="gallery-archive-title">
  <header class="section-heading">
    <p class="pixel-kicker">THE GALLERY OF FLOATING LIGHTS</p>
    <h2 id="gallery-archive-title">浮光廊</h2>
    <p>每件作品都保留创作时间、方式和来源说明；这里不陈列无出处的图片。</p>
  </header>

  <div class="filter-panel gallery-filters" aria-label="筛选作品">
    <div class="filter-group">
      <strong>作品门类</strong>
      <button class="filter-chip active" type="button" data-filter-type="category" data-filter-value="all" aria-pressed="true">全部</button>
      {categories.map((category) => <button class="filter-chip" type="button" data-filter-type="category" data-filter-value={category} aria-pressed="false">{category}</button>)}
    </div>
    {tags.length > 0 && (
      <div class="filter-group">
        <strong>灯下签记</strong>
        <button class="filter-chip active" type="button" data-filter-type="tag" data-filter-value="all" aria-pressed="true">全部</button>
        {tags.map((tag) => <button class="filter-chip" type="button" data-filter-type="tag" data-filter-value={tag} aria-pressed="false">#{tag}</button>)}
      </div>
    )}
    <div class="filter-summary">
      <p class="filter-count" aria-live="polite">共 {works.length} 件</p>
      <button type="button" class="filter-reset" data-reset-filters hidden>清除筛选</button>
    </div>
  </div>

  <div class="gallery-grid">
    {works.map((work) => (
      <article class="gallery-card" data-work-card data-category={work.data.category} data-tags={JSON.stringify(work.data.tags)}>
        <a class="gallery-card__cover" href={`/world/lantern-lane/${work.data.slug}/`} aria-label={`查看作品《${work.data.title}》`}>
          <Image src={work.data.cover} alt={work.data.coverAlt} widths={[480, 720, 960]} sizes="(max-width: 720px) 100vw, (max-width: 1100px) 50vw, 33vw" loading="lazy" />
          <span>{work.data.category}</span>
        </a>
        <div class="gallery-card__body">
          <time datetime={work.data.createdAt.toISOString()}>{formatDate(work.data.createdAt)}</time>
          <h3><a href={`/world/lantern-lane/${work.data.slug}/`}>{work.data.title}</a></h3>
          <p>{work.data.summary}</p>
          <div class="tag-row">{work.data.tags.map((tag) => <IslandTag label={tag} tone="yellow" />)}</div>
          <a class="text-link" href={`/world/lantern-lane/${work.data.slug}/`}>步入灯下观览 →</a>
        </div>
      </article>
    ))}
  </div>
  <div class="empty-state" data-empty-state hidden><strong>这条灯巷暂时没有对应作品。</strong><p>换一个门类，或清除当前筛选。</p></div>
</section>

<script>
  const browser = document.querySelector<HTMLElement>('[data-gallery-browser]');
  if (browser) {
    const state = { category: 'all', tag: 'all' };
    const cards = [...browser.querySelectorAll<HTMLElement>('[data-work-card]')];
    const count = browser.querySelector<HTMLElement>('.filter-count');
    const empty = browser.querySelector<HTMLElement>('[data-empty-state]');
    const reset = browser.querySelector<HTMLButtonElement>('[data-reset-filters]');
    const values = (type: 'category' | 'tag') => new Set([...browser.querySelectorAll<HTMLButtonElement>(`[data-filter-type="${type}"]`)].map((button) => button.dataset.filterValue || 'all'));
    const categoryValues = values('category');
    const tagValues = values('tag');

    const applyFilters = (updateUrl = false) => {
      let visible = 0;
      cards.forEach((card) => {
        const cardTags = JSON.parse(card.dataset.tags || '[]') as string[];
        const matchesCategory = state.category === 'all' || card.dataset.category === state.category;
        const matchesTag = state.tag === 'all' || cardTags.includes(state.tag);
        card.hidden = !(matchesCategory && matchesTag);
        if (!card.hidden) visible += 1;
      });
      browser.querySelectorAll<HTMLButtonElement>('[data-filter-type]').forEach((button) => {
        const type = button.dataset.filterType as 'category' | 'tag';
        const active = state[type] === (button.dataset.filterValue || 'all');
        button.classList.toggle('active', active);
        button.setAttribute('aria-pressed', String(active));
      });
      if (count) count.textContent = `共 ${visible} 件`;
      if (empty) empty.hidden = visible !== 0;
      if (reset) reset.hidden = state.category === 'all' && state.tag === 'all';
      if (updateUrl) {
        const url = new URL(window.location.href);
        for (const type of ['category', 'tag'] as const) {
          if (state[type] === 'all') url.searchParams.delete(type);
          else url.searchParams.set(type, state[type]);
        }
        history.replaceState(null, '', `${url.pathname}${url.search}${url.hash}`);
      }
    };

    const readUrl = () => {
      const params = new URLSearchParams(window.location.search);
      const category = params.get('category') || 'all';
      const tag = params.get('tag') || 'all';
      state.category = categoryValues.has(category) ? category : 'all';
      state.tag = tagValues.has(tag) ? tag : 'all';
      applyFilters(false);
    };

    browser.querySelectorAll<HTMLButtonElement>('[data-filter-type]').forEach((button) => {
      button.addEventListener('click', () => {
        const type = button.dataset.filterType as 'category' | 'tag';
        state[type] = button.dataset.filterValue || 'all';
        applyFilters(true);
      });
    });
    reset?.addEventListener('click', () => {
      state.category = 'all';
      state.tag = 'all';
      applyFilters(true);
    });
    window.addEventListener('popstate', readUrl);
    readUrl();
  }
</script>
