---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import IslandTag from '../../../components/IslandTag';
import { calculatePlanProgress, classifyDueDate, comparePlans } from '../../../utils/planProgress';
import { assertPlanProjectReferences } from '../../../schemas/plan';

export async function getStaticPaths() {
  const plans = (await getCollection('plans')).sort((left, right) => comparePlans(left.data, right.data));
  const projects = await getCollection('projects');
  const projectMap = new Map(projects.map((project) => [project.data.slug, project]));
  assertPlanProjectReferences(plans, projectMap.keys());
  return plans.map((plan, index) => ({
    params: { slug: plan.data.slug },
    props: {
      plan,
      project: plan.data.projectSlug ? projectMap.get(plan.data.projectSlug) : undefined,
      prev: plans[index - 1],
      next: plans[index + 1],
    },
  }));
}

const { plan, project, prev, next } = Astro.props;
const { Content } = await render(plan);
const progress = calculatePlanProgress(plan.data.milestones);
const formatDate = (date?: Date) => date ? new Intl.DateTimeFormat('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' }).format(date) : '未设日期';
const dateKey = (date?: Date) => date?.toISOString().slice(0, 10);
const statusCopy = { overdue: '已逾期', upcoming: '七天内', later: '', undated: '' } as const;
---

<BaseLayout
  title={plan.data.title}
  description={plan.data.summary}
  image={project?.data.cover}
  searchable
  searchType="推进"
  searchTitle={plan.data.title}
  searchCategory={plan.data.area}
  searchTags={plan.data.tags}
  searchDate={plan.data.updatedAt}
>
  <article class="plan-detail page-shell">
    <header class="plan-detail__header">
      <a class="back-link" href="/world/moon-pool/#plan-dashboard-title">← 返回月潭推进台</a>
      <p class="pixel-kicker">项目推进 · {plan.data.area}</p>
      <h1>{plan.data.title}</h1>
      <p>{plan.data.summary}</p>
      <div class="plan-detail__meta"><span>{plan.data.status}</span><strong>{plan.data.priority}优先</strong><time datetime={dateKey(plan.data.updatedAt)}>更新于 {formatDate(plan.data.updatedAt)}</time></div>
      <div class="tag-row">{plan.data.tags.map((tag) => <IslandTag label={tag} tone="teal" />)}</div>
    </header>

    <section class="plan-detail__progress" aria-labelledby="plan-progress-title">
      <div><p class="pixel-kicker">阶段进度</p><h2 id="plan-progress-title">里程碑完成度</h2></div>
      <strong>{progress === null ? '待拆解' : `${progress}%`}</strong>
      {progress !== null && <div role="progressbar" aria-label={`${plan.data.title}里程碑进度`} aria-valuemin="0" aria-valuemax="100" aria-valuenow={progress}><span style={`width:${progress}%`}></span></div>}
      <p>{plan.data.milestones.filter(({ status }) => status === '已完成').length} / {plan.data.milestones.length} 个里程碑已完成{plan.data.targetAt && <> · 目标日期 <time datetime={dateKey(plan.data.targetAt)}>{formatDate(plan.data.targetAt)}</time></>}</p>
    </section>

    <div class="plan-detail__columns">
      <section aria-labelledby="plan-milestones-title">
        <h2 id="plan-milestones-title">里程碑</h2>
        {plan.data.milestones.length > 0 ? <ol class="detail-milestones">{plan.data.milestones.map((milestone) => <li class:list={[`is-${milestone.status}`]}><span></span><div><small>{milestone.status}</small><strong>{milestone.title}</strong>{milestone.targetAt && <time datetime={dateKey(milestone.targetAt)}>{formatDate(milestone.targetAt)}</time>}</div></li>)}</ol> : <p class="plan-detail__empty">这项计划还没有拆解里程碑。</p>}
      </section>
      <section aria-labelledby="plan-actions-detail-title">
        <h2 id="plan-actions-detail-title">下一步行动</h2>
        {plan.data.nextActions.length > 0 ? <ul class="detail-actions">{plan.data.nextActions.map((action) => {
          const dueState = action.status === '已完成' ? 'done' : classifyDueDate(action.dueAt);
          return <li class:list={[`is-${dueState}`]}><span>{action.status}</span><div><strong>{action.title}</strong>{action.dueAt && <p><time datetime={dateKey(action.dueAt)}>{formatDate(action.dueAt)}</time> <em>{dueState === 'done' ? '' : statusCopy[dueState]}</em></p>}</div></li>;
        })}</ul> : <p class="plan-detail__empty">当前没有行动项。</p>}
      </section>
    </div>

    {project && <aside class="plan-linked-project"><div><p class="pixel-kicker">关联档案</p><h2>{project.data.title}</h2><p>{project.data.description}</p></div><a href={`/projects/${project.data.slug}/`}>查看稳定项目档案 →</a></aside>}

    <section class="plan-log prose" aria-labelledby="plan-log-title"><h2 id="plan-log-title">推进记录</h2><Content /></section>

    <nav class="article-nav" aria-label="相邻计划">
      {prev ? <a href={`/world/moon-pool/${prev.data.slug}/`}><small>上一项计划</small><strong>{prev.data.title}</strong></a> : <span></span>}
      {next ? <a href={`/world/moon-pool/${next.data.slug}/`}><small>下一项计划</small><strong>{next.data.title}</strong></a> : <span></span>}
    </nav>
  </article>
</BaseLayout>

<style>
  .plan-detail { padding: 150px 0 110px; color: #526058; }
  .plan-detail__header { max-width: 850px; margin: 0 auto 45px; padding: 34px 38px; border: 3px solid #636f67; background: rgba(248,245,224,.95); box-shadow: 7px 7px 0 rgba(53,65,57,.28); }
  .plan-detail__header h1 { margin: 10px 0 15px; color: #514838; font-family: var(--serif); font-size: clamp(2.4rem, 6vw, 4.3rem); line-height: 1.25; }
  .plan-detail__header > p:not(.pixel-kicker) { max-width: 700px; line-height: 1.85; }
  .plan-detail__meta { display: flex; flex-wrap: wrap; gap: 10px; margin: 22px 0 17px; }
  .plan-detail__meta > * { padding: 5px 9px; color: #516257; background: #dce5d5; font-size: .72rem; }
  .plan-detail__progress { display: grid; grid-template-columns: 1fr auto; gap: 14px 24px; max-width: 850px; margin: 0 auto 28px; padding: 25px 28px; border: 3px solid #657169; background: #e9eddc; }
  .plan-detail__progress h2 { margin: 0; color: #514838; font-family: var(--serif); }
  .plan-detail__progress > strong { align-self: end; color: #416451; font-family: var(--serif); font-size: 2rem; }
  .plan-detail__progress > div[role='progressbar'] { grid-column: 1 / -1; height: 14px; overflow: hidden; border: 2px solid #68766d; background: #d5ddcf; }
  .plan-detail__progress > div[role='progressbar'] span { display: block; height: 100%; background: repeating-linear-gradient(90deg, #76a081 0 11px, #8db397 11px 19px); }
  .plan-detail__progress > p { grid-column: 1 / -1; margin: 0; font-size: .74rem; }
  .plan-detail__columns { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 24px; max-width: 1000px; margin: 0 auto 28px; }
  .plan-detail__columns > section { padding: 27px; border: 3px solid #69736d; background: rgba(244,243,222,.9); }
  .plan-detail__columns h2 { margin: 0 0 22px; color: #514838; font-family: var(--serif); font-size: 1.55rem; }
  .detail-milestones, .detail-actions { display: grid; gap: 15px; margin: 0; padding: 0; list-style: none; }
  .detail-milestones li { display: grid; grid-template-columns: 16px 1fr; gap: 11px; }
  .detail-milestones li > span { width: 13px; height: 13px; margin-top: 5px; border: 2px solid #6f7d73; background: #faf7e3; }
  .detail-milestones li.is-已完成 > span { background: #73a080; box-shadow: inset 0 0 0 2px #eceddc; }
  .detail-milestones li.is-进行中 > span { background: #e1bc61; }
  .detail-milestones small, .detail-milestones strong, .detail-milestones time { display: block; }
  .detail-milestones small, .detail-milestones time { color: #738078; font-size: .68rem; }
  .detail-actions li { display: grid; grid-template-columns: 58px 1fr; gap: 10px; padding-bottom: 13px; border-bottom: 1px dashed #969b91; }
  .detail-actions li > span { color: #466854; font-size: .7rem; font-weight: 900; }
  .detail-actions strong { display: block; }
  .detail-actions p { margin: 4px 0 0; color: #748078; font-size: .68rem; }
  .detail-actions em { color: #9c5b42; font-style: normal; font-weight: 900; }
  .detail-actions li.is-done { opacity: .65; }
  .detail-actions li.is-overdue { color: #8f4f3d; }
  .plan-linked-project { display: flex; align-items: end; justify-content: space-between; gap: 25px; max-width: 1000px; margin: 0 auto 28px; padding: 25px 28px; border-left: 6px solid #66917a; background: #e2eadb; }
  .plan-linked-project h2 { margin: 0 0 7px; color: #514838; font-family: var(--serif); }
  .plan-linked-project p:last-child { margin: 0; }
  .plan-linked-project > a { flex: 0 0 auto; color: #3f6651; font-weight: 900; }
  .plan-log { max-width: 820px; margin: 54px auto; }
  .plan-log > h2 { color: #514838; font-family: var(--serif); font-size: 2rem; }
  @media (max-width: 700px) {
    .plan-detail { padding-top: 120px; }
    .plan-detail__header { padding: 27px 20px; }
    .plan-detail__columns { grid-template-columns: 1fr; }
    .plan-linked-project { align-items: start; flex-direction: column; }
  }
  @media (prefers-reduced-motion: reduce) { .plan-detail__progress > div[role='progressbar'] span { background: #76a081; } }
</style>
