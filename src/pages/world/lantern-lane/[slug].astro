---
import { getCollection, render } from 'astro:content';
import WorkLayout from '../../../layouts/WorkLayout.astro';

export async function getStaticPaths() {
  const works = (await getCollection('works', ({ data }) => !data.draft))
    .sort((a, b) => b.data.createdAt.valueOf() - a.data.createdAt.valueOf());
  return works.map((work, index) => ({
    params: { slug: work.data.slug },
    props: { work, prev: works[index - 1], next: works[index + 1] },
  }));
}

const { work, prev, next } = Astro.props;
const { Content } = await render(work);
---

<WorkLayout {...work.data} prev={prev} next={next}>
  <Content />
</WorkLayout>
