---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import CloudEntrance from '../components/CloudEntrance';
import IslandTag from '../components/IslandTag';
import VillageMap from '../components/VillageMap';
import { villageCopy } from '../data/villageCopy';

const notes = (await getCollection('notes', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
const projects = (await getCollection('projects'))
  .sort((a, b) => Number(b.data.featured) - Number(a.data.featured));
const featuredProjects = projects.filter(({ data }) => data.featured).slice(0, 2);
const recentNotes = notes.slice(0, 3);
const formatDate = (date: Date) => new Intl.DateTimeFormat('zh-CN', { month: '2-digit', day: '2-digit' }).format(date);

const backgrounds = Object.fromEntries(['dawn', 'day', 'dusk', 'night'].map((time) => [time, {
  avif: `/images/village/${time}/village-desktop.avif`,
  webp: `/images/village/${time}/village-desktop.webp`,
  mobileAvif: `/images/village/${time}/village-mobile.avif`,
  mobileWebp: `/images/village/${time}/village-mobile.webp`,
}])) as Record<'dawn' | 'day' | 'dusk' | 'night', { avif: string; webp: string; mobileAvif: string; mobileWebp: string }>;

const locations = [
  {
    id: 'study' as const,
    href: '/notes',
    ...villageCopy.places.study,
    items: recentNotes.slice(0, 3).map((note) => ({ href: `/notes/${note.data.slug}/`, label: note.data.title, meta: note.data.category })),
  },
  {
    id: 'workshop' as const,
    href: '/projects',
    ...villageCopy.places.workshop,
    items: projects.slice(0, 3).map((project) => ({ href: `/projects/${project.data.slug}/`, label: project.data.title, meta: project.data.status })),
  },
  {
    id: 'mountain' as const,
    href: '/about',
    ...villageCopy.places.mountain,
    items: [
      { href: '/about#education', label: '软件工程本科', meta: '教育' },
      { href: '/about#skills', label: 'Python · 机器学习', meta: '技能' },
      { href: '/about#honors', label: '奖学金与学科竞赛', meta: '荣誉' },
    ],
  },
];
---

<BaseLayout image="/images/village/day/village-desktop.webp">
  <CloudEntrance client:only="react" />
  <VillageMap
    client:load
    backgrounds={backgrounds}
    locations={locations}
    title={villageCopy.gateway.title}
    eyebrow={villageCopy.gateway.eyebrow}
    lead={villageCopy.gateway.lead}
    timeCopy={villageCopy.times}
    imageAlt="王选默的个人数字村落，云门、春水、山窗书屋、百工阁与关于页面沿石径相连"
  />

  <section id="village-content" class="village-bulletin">
    <div class="page-shell bulletin-layout">
      <header class="bulletin-heading cloud-sign">
        <p class="pixel-kicker">{villageCopy.bulletin.eyebrow}</p>
        <h2>{villageCopy.bulletin.title}</h2>
        <p>{villageCopy.bulletin.lead}</p>
      </header>

      <div class="bulletin-notes">
        <span class="bulletin-label">山窗新笺</span>
        {recentNotes.map((note, index) => (
          <a class:list={['bulletin-note', `bulletin-note--${index + 1}`]} href={`/notes/${note.data.slug}/`}>
            <span class="bulletin-note__pin" aria-hidden="true"></span>
            <time datetime={note.data.publishedAt.toISOString()}>{formatDate(note.data.publishedAt)}</time>
            <small>{note.data.category}</small>
            <h3>{note.data.title}</h3>
            <p>{note.data.description}</p>
            <span class="bulletin-note__action">展笺阅读 →</span>
          </a>
        ))}
      </div>

      <div class="bulletin-projects">
        <div class="workshop-ruler" aria-hidden="true"><span>01</span><span>02</span><span>03</span><span>04</span></div>
        <span class="bulletin-label">工坊近作</span>
        {featuredProjects.map((project, index) => (
          <article class:list={['workshop-ticket', `workshop-ticket--${index + 1}`]}>
            <div><small>{project.data.period}</small><strong>{project.data.status}</strong></div>
            <h3><a href={`/projects/${project.data.slug}/`}>{project.data.title}</a></h3>
            <p>{project.data.description}</p>
            <div class="tag-row">{project.data.stack.map((item) => <IslandTag label={item} tone="green" />)}</div>
            <a class="text-link" href={`/projects/${project.data.slug}/`}>查看工坊档案 →</a>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
