---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import CloudEntrance from '../components/CloudEntrance';
import IslandTag from '../components/IslandTag';
import VillageJourney from '../components/VillageJourney';

const notes = (await getCollection('notes', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 3);
const projects = (await getCollection('projects'))
  .filter(({ data }) => data.featured)
  .slice(0, 2);
const formatDate = (date: Date) => new Intl.DateTimeFormat('zh-CN', { month: '2-digit', day: '2-digit' }).format(date);
const journeyLocations = [
  { href: '/notes', kind: 'study' as const, eyebrow: '山窗书屋', title: '翻阅云笺', description: '生活札记、学习笔记，以及值得反复推敲的问题。' },
  { href: '/projects', kind: 'workshop' as const, eyebrow: '百工阁', title: '查看造物', description: '项目经历、技术选择与仍在生长的构想。' },
  { href: '/about', kind: 'mountain' as const, eyebrow: '三山观', title: '登山远望', description: '来路、此刻，以及想要前往的方向。' },
];
---

<BaseLayout>
  <CloudEntrance client:only="react" />
  <VillageJourney
    client:load
    imageSrc="/images/yuncun-cloudwall.webp"
    imageAlt="一位旅人乘着小舟穿过风雨与厚重云墙，望见晨光中宁静的青山、春水与茅屋"
    locations={journeyLocations}
  />

  <section id="village-content" class="stream-section">
    <div class="page-shell stream-grid">
      <div class="section-heading">
        <p class="eyebrow">RECENT CLOUD NOTES</p>
        <h2>新到的云笺</h2>
        <p>一些刚刚从山窗寄出的文字，带着未干的墨与清晨的风。</p>
        <a class="text-link" href="/notes">查看全部笔记 →</a>
      </div>
      <div class="note-list">
        {notes.map((note, index) => (
          <a class="note-row" href={`/notes/${note.id}/`}>
            <span class="note-row__date">{formatDate(note.data.publishedAt)}</span>
            <div><small>{note.data.category}</small><h3>{note.data.title}</h3><p>{note.data.description}</p></div>
            <span class="note-row__index">0{index + 1}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="work-section page-shell">
    <div class="section-heading section-heading--split">
      <div><p class="eyebrow">SELECTED WORKS</p><h2>工坊近作</h2></div>
      <a class="text-link" href="/projects">全部行迹 →</a>
    </div>
    <div class="featured-projects">
      {projects.map((project) => (
        <article class="project-preview">
          <div class="project-preview__top"><span>{project.data.period}</span><strong>{project.data.status}</strong></div>
          <h3>{project.data.title}</h3>
          <p>{project.data.description}</p>
          <div class="tag-row">{project.data.stack.map((item) => <IslandTag label={item} tone="green" />)}</div>
        </article>
      ))}
    </div>
  </section>

  <section class="quote-section">
    <div class="quote-section__cloud" aria-hidden="true"></div>
    <blockquote>“人在，村在，梦在，魂在，足矣。”</blockquote>
    <p>——《闲梦 · 云村》</p>
  </section>
</BaseLayout>
