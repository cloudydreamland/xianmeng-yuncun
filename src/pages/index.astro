---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import CloudEntrance from '../components/CloudEntrance';
import IslandTag from '../components/IslandTag';
import PlanSummary from '../components/PlanSummary.astro';
import WorldMap from '../components/WorldMap';
import {
  cloudVillageDestinations,
  timeCopy,
  worldBackgrounds,
  worldMapPoints,
} from '../data/worldMap';

const notes = (await getCollection('notes', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
const projects = (await getCollection('projects'))
  .sort((a, b) => Number(b.data.featured) - Number(a.data.featured));
const plans = await getCollection('plans');
const regions = (await getCollection('regions'))
  .sort((a, b) => a.data.order - b.data.order);
const featuredProjects = projects.filter(({ data }) => data.featured).slice(0, 2);
const recentNotes = notes.slice(0, 3);
const formatDate = (date: Date) => new Intl.DateTimeFormat('zh-CN', { month: '2-digit', day: '2-digit' }).format(date);

const pointsById = new Map(worldMapPoints.map((point) => [point.id, point]));
const mapRegions = regions.map((region) => {
  const point = pointsById.get(region.data.slug as typeof worldMapPoints[number]['id']);
  if (!point) throw new Error(`缺少区域坐标：${region.data.slug}`);
  return {
    id: point.id,
    href: `/world/${region.data.slug}/`,
    realm: region.data.realm,
    title: region.data.title,
    summary: region.data.summary,
    quote: region.data.quote,
    functionTitle: region.data.functionTitle,
    functionDescription: region.data.functionDescription,
    status: region.data.status,
    x: point.x,
    y: point.y,
    labelSide: point.labelSide,
    items: point.id === 'cloud-village' ? cloudVillageDestinations : undefined,
  };
});
---

<BaseLayout preloadWorldMap>
  <CloudEntrance client:only="react" />
  <WorldMap
    client:load
    backgrounds={worldBackgrounds}
    regions={mapRegions}
    timeCopy={timeCopy}
    imageAlt="雲梦世界全境图：云村居中，雪崖、星渊、风谷、月潭、雨桥与浮屿灯巷环绕在云海之上"
  />

  <section id="village-content" class="village-bulletin">
    <div class="page-shell bulletin-layout">
      <PlanSummary plans={plans} />
      <header class="bulletin-heading cloud-sign">
        <p class="pixel-kicker">云村近况</p>
        <h2>云村近况</h2>
        <p>全境辽阔，真正的学习与造物仍从村中的一页纸、一道代码开始。</p>
      </header>

      <div class="bulletin-notes">
        <span class="bulletin-label">风谷新信</span>
        {recentNotes.map((note, index) => (
          <a class:list={['bulletin-note', `bulletin-note--${index + 1}`]} href={`/notes/${note.data.slug}/`}>
            <span class="bulletin-note__pin" aria-hidden="true"></span>
            <time datetime={note.data.publishedAt.toISOString()}>{formatDate(note.data.publishedAt)}</time>
            <small>{note.data.category}</small>
            <h3>{note.data.title}</h3>
            <p>{note.data.description}</p>
            <span class="bulletin-note__action">展笺阅读 →</span>
          </a>
        ))}
      </div>

      <div class="bulletin-projects">
        <div class="workshop-ruler" aria-hidden="true"><span>01</span><span>02</span><span>03</span><span>04</span></div>
        <span class="bulletin-label">月潭近档</span>
        {featuredProjects.map((project, index) => (
          <article class:list={['workshop-ticket', `workshop-ticket--${index + 1}`]}>
            <div><small>{project.data.period}</small><strong>{project.data.status}</strong></div>
            <h3><a href={`/projects/${project.data.slug}/`}>{project.data.title}</a></h3>
            <p>{project.data.description}</p>
            <div class="tag-row">{project.data.stack.map((item) => <IslandTag label={item} tone="green" />)}</div>
            <a class="text-link" href={`/projects/${project.data.slug}/`}>查看月映档案 →</a>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
