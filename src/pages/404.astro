---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="迷失云海" description="这条山路暂时没有通往任何地方。">
  <section class="not-found page-shell">
    <div class="not-found__number">404</div>
    <p class="eyebrow">LOST IN THE CLOUDS</p>
    <h1>似乎在云海中迷了路</h1>
    <p>风把路牌吹向了另一边。这一页也许尚未建成，或已经随着云散去了。</p>
    <a class="button button--primary" href="/">循水声回到云渡</a>
  </section>
</BaseLayout>
