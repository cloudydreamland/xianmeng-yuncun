---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="前往月潭" description="项目入口已迁往月潭。">
  <section class="redirect-page page-shell">
    <p class="pixel-kicker">入口已迁移</p>
    <h1>项目已迁往月潭</h1>
    <p>项目档案、技术选择与复盘现在由月潭承接。</p>
    <a class="button button--primary" href="/world/moon-pool/">进入月潭</a>
  </section>
  <script is:inline>window.location.replace('/world/moon-pool/');</script>
</BaseLayout>
