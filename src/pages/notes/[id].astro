---
import { getCollection, render } from 'astro:content';
import NoteLayout from '../../layouts/NoteLayout.astro';
import { getReadingStats } from '../../utils/readingStats';

export async function getStaticPaths() {
  const notes = (await getCollection('notes', ({ data }) => !data.draft))
    .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
  return notes.map((note, index) => ({
    params: { id: note.id },
    props: {
      note,
      prev: notes[index + 1],
      next: notes[index - 1],
    },
  }));
}

const { note, prev, next } = Astro.props;
const { Content, headings } = await render(note);
const readingStats = getReadingStats(note.body ?? '');
---

<NoteLayout {...note.data} {...readingStats} headings={headings} prev={prev} next={next}>
  <Content />
</NoteLayout>
