---
import '@fontsource/noto-serif-sc/400.css';
import '@fontsource/noto-serif-sc/700.css';
import 'animal-island-ui/style';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SearchPanel from '../components/SearchPanel.astro';
import { worldBackgrounds } from '../data/worldMap';
import { villageBackgrounds } from '../data/villageBackgrounds';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  searchable?: boolean;
  searchType?: '笔记' | '项目' | '推进' | '关于' | '世界' | '作品';
  searchTitle?: string;
  searchCategory?: string;
  searchTags?: string[];
  searchDate?: Date;
}

const {
  title = '雲梦世界',
  description = '以云村为中心、六境环绕的个人数字世界，收纳学习笔记、项目档案与持续生长的想法。',
  image = worldBackgrounds.day.fallback,
  searchable = false,
  searchType,
  searchTitle,
  searchCategory,
  searchTags = [],
  searchDate,
} = Astro.props;
const pageTitle = title === '雲梦世界' ? title : `${title}｜雲梦世界`;
const canonical = new URL(Astro.url.pathname, Astro.site);
const imageUrl = new URL(image, Astro.site);
const villageBackgroundStyle = (['dawn', 'day', 'dusk', 'night'] as const)
  .flatMap((time) => [
    `--village-bg-${time}:${villageBackgrounds[time].desktop}`,
    `--village-bg-${time}-mobile:${villageBackgrounds[time].mobile}`,
  ])
  .join(';');
---

<!doctype html>
<html lang="zh-CN" style={villageBackgroundStyle}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#edf4e6" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title="雲梦世界订阅" href="/rss.xml" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={imageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    {searchable && searchType && <meta data-pagefind-filter={`contentType:${searchType}`} />}
    {searchable && searchType && <meta data-pagefind-meta="contentType[content]" content={searchType} />}
    {searchable && searchTitle && <meta data-pagefind-meta="title[content]" content={searchTitle} />}
    {searchable && <meta data-pagefind-meta="description[content]" content={description} />}
    {searchable && searchCategory && <meta data-pagefind-filter="category[content]" content={searchCategory} />}
    {searchable && searchTags.map((tag) => <meta data-pagefind-filter="tag[content]" content={tag} />)}
    {searchable && searchDate && <meta data-pagefind-sort="date[content]" content={searchDate.toISOString()} />}
    <title>{pageTitle}</title>
    <script is:inline>
      (() => {
        const root = document.documentElement;
        root.classList.add('js');
        let mode = 'auto';
        try {
          const stored = localStorage.getItem('yuncun-time-mode');
          if (['auto', 'dawn', 'day', 'dusk', 'night'].includes(stored || '')) mode = stored;
        } catch {}
        const hour = new Date().getHours();
        const resolved = mode !== 'auto' ? mode : hour >= 5 && hour < 8 ? 'dawn' : hour >= 8 && hour < 17 ? 'day' : hour >= 17 && hour < 20 ? 'dusk' : 'night';
        root.dataset.time = resolved;
        root.dataset.timeMode = mode;
      })();
    </script>
  </head>
  <body class:list={[{ 'home-page': Astro.url.pathname === '/' }]}>
    <a class="skip-link" href="#main-content">跳到主要内容</a>
    <div class="paper-noise" aria-hidden="true"></div>
    <Header />
    <SearchPanel />
    <main id="main-content" data-pagefind-body={searchable ? true : undefined}><slot /></main>
    <Footer />
    <div id="yunling-pet-root" aria-hidden="true"></div>
  </body>
</html>
