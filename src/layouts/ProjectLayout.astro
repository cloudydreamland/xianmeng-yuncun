---
import BaseLayout from './BaseLayout.astro';
import IslandTag from '../components/IslandTag';
import { calculatePlanProgress, comparePlans } from '../utils/planProgress';
import type { CollectionEntry } from 'astro:content';

const {
  title,
  description,
  period,
  status,
  stack = [],
  repoUrl,
  demoUrl,
  cover,
  coverAlt,
  prev,
  next,
  linkedPlans: rawLinkedPlans = [],
} = Astro.props;
const linkedPlans = rawLinkedPlans as CollectionEntry<'plans'>[];
linkedPlans.sort((left, right) => comparePlans(left.data, right.data));
---

<BaseLayout
  title={title}
  description={description}
  image={cover}
  searchable
  searchType="项目"
  searchTitle={title}
  searchTags={stack}
>
  <article class="project-detail page-shell">
    <header class="project-detail__header">
      <a class="back-link" href="/world/moon-pool/">← 返回月潭</a>
      <p class="pixel-kicker">月映档案 · {status}</p>
      <h1>{title}</h1>
      <p class="project-detail__lead">{description}</p>
      <div class="project-detail__meta">
        <span>{period}</span>
        <strong>{status}</strong>
      </div>
      <div class="tag-row">
        {stack.map((item: string) => <IslandTag label={item} tone="green" />)}
      </div>
      {(demoUrl || repoUrl) && (
        <div class="project-detail__actions">
          {demoUrl && <a class="button button--primary" href={demoUrl} target="_blank" rel="noreferrer">查看成品 ↗</a>}
          {repoUrl && <a class="button button--ghost" href={repoUrl} target="_blank" rel="noreferrer">浏览源代码 ↗</a>}
        </div>
      )}
    </header>

    {cover && (
      <figure class="content-cover content-cover--project">
        <img src={cover} alt={coverAlt || title} width="1200" height="675" loading="eager" />
      </figure>
    )}

    {linkedPlans.length > 0 && (
      <section class="project-plan-links" aria-labelledby="project-plan-links-title">
        <header><p class="pixel-kicker">当前推进</p><h2 id="project-plan-links-title">与此档案关联的计划</h2></header>
        <div>
          {linkedPlans.map((plan) => {
            const progress = calculatePlanProgress(plan.data.milestones);
            return <a href={`/world/moon-pool/${plan.data.slug}/`}>
              <span>{plan.data.status} · {plan.data.area}</span>
              <strong>{plan.data.title}</strong>
              <div role={progress === null ? undefined : 'progressbar'} aria-label={progress === null ? '尚未拆解里程碑' : `${plan.data.title}里程碑进度`} aria-valuemin={progress === null ? undefined : 0} aria-valuemax={progress === null ? undefined : 100} aria-valuenow={progress ?? undefined}><i style={`width:${progress ?? 0}%`}></i></div>
              <small>{progress === null ? '待拆解' : `${progress}%`} · 返回月潭查看下一步 →</small>
            </a>;
          })}
        </div>
      </section>
    )}

    <div class="project-detail__body prose"><slot /></div>

    <nav class="article-nav" aria-label="相邻项目">
      {prev ? <a href={`/projects/${prev.data.slug}/`}><small>上一份档案</small><strong>{prev.data.title}</strong></a> : <span></span>}
      {next ? <a href={`/projects/${next.data.slug}/`}><small>下一份档案</small><strong>{next.data.title}</strong></a> : <span></span>}
    </nav>
  </article>
</BaseLayout>

<style>
  .project-plan-links { max-width: 920px; margin: -30px auto 62px; padding: 25px 28px; border: 3px solid #657169; color: #56635b; background: #edf0de; box-shadow: 6px 6px 0 rgba(54,67,59,.24); }
  .project-plan-links header { margin-bottom: 18px; }
  .project-plan-links h2 { margin: 0; color: #514838; font-family: var(--serif); font-size: 1.5rem; }
  .project-plan-links > div { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 13px; }
  .project-plan-links a { display: block; padding: 17px 18px; border: 2px solid #7e887f; background: #f8f5df; }
  .project-plan-links a > span, .project-plan-links a > strong, .project-plan-links a > small { display: block; }
  .project-plan-links a > span, .project-plan-links a > small { color: #647168; font-size: .7rem; }
  .project-plan-links a > strong { margin: 6px 0 12px; color: #4e4a3d; font-family: var(--serif); }
  .project-plan-links a > div { height: 8px; overflow: hidden; margin-bottom: 7px; border: 1px solid #657269; background: #d7ded0; }
  .project-plan-links i { display: block; height: 100%; background: #78a083; }
  @media (max-width: 600px) { .project-plan-links { padding: 21px 18px; } .project-plan-links > div { grid-template-columns: 1fr; } }
</style>
