---
import BaseLayout from './BaseLayout.astro';

const {
  title,
  realm,
  summary,
  quote,
  functionTitle,
  functionDescription,
  status,
  theme,
  illustration,
  prev,
  next,
} = Astro.props;
---

<BaseLayout
  title={`${title}｜雲梦地志`}
  description={summary}
  image={illustration.fallback}
  searchable
  searchType="世界"
  searchTitle={title}
>
  <article class={`region-page region-page--${theme}`}>
    <header class="region-hero page-shell">
      <a class="back-link" href="/">← 返回雲梦全境</a>
      <div class="region-hero__copy">
        <p class="pixel-kicker">雲梦地志 · {realm}</p>
        <h1>{title}</h1>
        <p>{summary}</p>
        <span class:list={['region-status', { 'region-status--active': status === 'active' }]}>
          {status === 'active' ? '此境已开放' : '设定已开放 · 功能酝酿中'}
        </span>
      </div>
      <figure class="region-visual">
        <picture>
          <source type="image/avif" srcset={illustration.avifSrcSet} sizes={illustration.sizes} />
          <source type="image/webp" srcset={illustration.webpSrcSet} sizes={illustration.sizes} />
          <img data-region-hero-image src={illustration.fallback} alt={illustration.alt} width="1600" height="900" loading="eager" fetchpriority="high" decoding="sync" />
        </picture>
      </figure>
      <blockquote>{quote}</blockquote>
    </header>

    <div class="region-story page-shell">
      <div class="region-story__body prose"><slot name="story" /></div>
      <aside class="region-function pixel-frame">
        <p class="pixel-kicker">此境所司</p>
        <h2>{functionTitle}</h2>
        <p>{functionDescription}</p>
        <strong>{status === 'active' ? '当前可用' : '首版不放置无效入口'}</strong>
      </aside>
    </div>

    <div class="region-feature page-shell"><slot /></div>

    <nav class="region-nav page-shell" aria-label="相邻区域">
      {prev ? <a href={`/world/${prev.data.slug}/`}><small>上一境</small><strong>{prev.data.title}</strong></a> : <span></span>}
      {next ? <a href={`/world/${next.data.slug}/`}><small>下一境</small><strong>{next.data.title}</strong></a> : <span></span>}
    </nav>
  </article>
</BaseLayout>
