# Optional: enable R2 + Cloudflare Images delivery after binding an image domain.
# Example: https://img.example.com
PUBLIC_MEDIA_ORIGIN=

# Zone where Cloudflare Images transformations are enabled.
# Example: https://example.com
PUBLIC_IMAGE_TRANSFORM_ORIGIN=

# Canonical public website URL.
PUBLIC_SITE_URL=https://xianmeng-yuncun.pages.dev
